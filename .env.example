# Kopilkin local development environment example
# Copy this file to .env and replace values if needed.

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
TRANSACTION_SERVICE_URL=http://host.docker.internal:8002
QDRANT_HOST=qdrant
QDRANT_PORT=6333

LANGFUSE_PUBLIC_KEY=replace-with-your-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-your-langfuse-secret-key
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_BASE_URL=http://langfuse:3000

NEXTAUTH_SECRET=replace-with-random-local-secret
SALT=replace-with-random-local-salt
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=langfuse
